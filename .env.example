# Copy this file to `.env` (gitignored) and fill in real values.
# All keys are required — env.ts will throw at runtime if any is missing.

# Live staging WordPress site under test
STAGING_URL=https://your-staging-site.example.com

# Administrator credentials (used by loginAsAdmin and REST nonce fetches)
STAGING_USER=admin-email-or-username
STAGING_PASS=admin-password

# Author-role user used by the 02f Access & Restrictions deep tests
# (must be a real WP user with the Author role; User Switching plugin should be active)
STAGING_AUTHOR_LOGIN=author-email-or-username
STAGING_AUTHOR_PASS=author-password
