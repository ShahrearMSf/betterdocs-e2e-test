{
  "name": "betterdocs-e2e-test",
  "version": "1.0.0",
  "private": true,
  "description": "Admin-end Playwright E2E test suite for BetterDocs (Free, Pro, AI Chatbot) running against a live staging WordPress site.",
  "scripts": {
    "test": "playwright test --config=playwright.staging.config.js",
    "test:tier1": "playwright test --config=playwright.staging.config.js --project=tier1-free",
    "test:tier2": "playwright test --config=playwright.staging.config.js --project=tier2-pro",
    "test:tier3": "playwright test --config=playwright.staging.config.js --project=tier3-chatbot",
    "test:themes": "playwright test --config=playwright.staging.config.js --project=themes",
    "test:headed": "playwright test --config=playwright.staging.config.js --headed",
    "report": "playwright show-report playwright-report-staging"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  },
  "license": "GPL-3.0-or-later"
}
